# ── Required ─────────────────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-key-here

# ── Optional: fallback providers ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection (defaults use free Gemini 2.5 tier) ──────────────────────
LLM_PROVIDER=google
LLM_MODEL_FAST=gemini-2.5-flash      # scraping, form-filling, critic pass
LLM_MODEL_QUALITY=gemini-2.5-pro     # JD analysis, resume routing

# ── Job board credentials ─────────────────────────────────────────────────────
HANDSHAKE_EMAIL=your@email.com
HANDSHAKE_PASSWORD=your-password
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# ── Pipeline behavior ─────────────────────────────────────────────────────────
AUTO_SUBMIT=true                 # set to false to fill but not submit
SCRAPE_INTERVAL_MINUTES=60       # how often the sourcer runs
MIN_RELEVANCE_SCORE=0.5          # jobs below this score are skipped

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
SECRET_KEY=change-me-to-something-random
