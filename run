#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Job Applier — One-command launcher
# Usage:  ./run
#         ./run --api-only     (dashboard only, no agent)
#         ./run --run-once     (single pipeline pass)
#         ./run dashboard      (open dashboard dev server for UI work)
#         ./run install        (just install deps, don't run)
# ─────────────────────────────────────────────────────────────────────────────

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# ── Helpers ────────────────────────────────────────────────────────────────
bold() { printf '\033[1m%s\033[0m\n' "$*"; }
info() { printf '\033[34m→\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
err()  { printf '\033[31m✗\033[0m %s\n' "$*" >&2; exit 1; }

# ── Check uv ──────────────────────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
  info "uv not found. Installing via Homebrew..."
  brew install uv || err "Could not install uv. Install manually: https://docs.astral.sh/uv/"
fi

# ── Ensure .env exists ────────────────────────────────────────────────────
if [ ! -f .env ]; then
  info "No .env found — copying from .env.example"
  cp .env.example .env
  echo ""
  bold "⚠️  Please edit .env and add your OPENAI_API_KEY before running the agent."
  echo "   You can set it with:  nano .env"
  echo ""
fi

# ── Subcommands ───────────────────────────────────────────────────────────
case "${1:-}" in
  install)
    info "Installing Python 3.12 (if needed) and all dependencies..."
    uv python install 3.12
    uv sync
    uv run playwright install chromium
    ok "Dependencies installed."
    echo ""
    bold "Next steps:"
    echo "  1. Edit .env — add your OPENAI_API_KEY"
    echo "  2. Drop resume PDFs in src/resumes/  (e.g. finance.pdf, consulting.pdf)"
    echo "  3. Fill in src/config/profile.yaml"
    echo "  4. Run: ./run"
    exit 0
    ;;

  dashboard)
    info "Starting dashboard dev server at http://localhost:5173"
    cd dashboard && npm run dev
    exit 0
    ;;

  *)
    # Default: install deps if needed, then run the agent
    if [ ! -d ".venv" ]; then
      info "First run — setting up Python 3.12 environment..."
      uv python install 3.12
      uv sync
      uv run playwright install chromium
      ok "Setup complete."
      echo ""
    fi

    # Ensure dashboard is built and watch for changes in the background
    if [ -d "dashboard" ] && command -v npm &>/dev/null; then
      if [ ! -d "dashboard/dist" ]; then
        info "Building dashboard..."
        (cd dashboard && npm run build) && ok "Dashboard built."
      fi
      info "Watching dashboard for changes (auto-rebuild on save)..."
      (cd dashboard && npm run build -- --watch 2>&1 | grep -v "^$") &
      DASHBOARD_WATCHER_PID=$!
      trap "kill $DASHBOARD_WATCHER_PID 2>/dev/null" EXIT
    fi

    bold "🤖 Launching Job Applier Agent..."
    echo ""
    info "Dashboard → http://localhost:8000"
    echo ""

    # Pass through any flags (--api-only, --run-once, etc.)
    uv run python -m src.main "$@"
    ;;
esac
