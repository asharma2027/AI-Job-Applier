# ============================================================
# Autonomous Job Application Agent — Environment Config
# Copy this file to .env and fill in your values.
# ============================================================

# LLM Provider (choose one)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai          # openai | anthropic | ollama
LLM_MODEL=gpt-4o             # e.g. gpt-4o, claude-3-5-sonnet-latest, llama3.2

# Handshake credentials (for authenticated browsing)
HANDSHAKE_EMAIL=you@university.edu
HANDSHAKE_PASSWORD=your_password_here

# LinkedIn credentials (optional)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Application settings
AUTO_SUBMIT=true             # true = auto-submit, false = pause before submit
SCRAPE_INTERVAL_MINUTES=60   # how often to run the sourcing agent
MIN_RELEVANCE_SCORE=0.5      # jobs below this score are auto-skipped (0.0 - 1.0)

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
SECRET_KEY=change-this-to-a-random-secret  # for session signing

# Database
DATABASE_URL=sqlite+aiosqlite:///./job_applier.db

# Paths
RESUMES_DIR=./src/resumes
COVER_LETTER_TEMPLATE=./src/templates/cover_letter_template.md
RECORDS_DIR=./records
